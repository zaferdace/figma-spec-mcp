{
  "name": "figma-spec-mcp",
  "version": "1.0.0-beta.3",
  "description": "Bridge Figma to any platform — Unity UGUI mappings, design tokens for React/Flutter/SwiftUI/Tailwind, accessibility audits, and AI-optimized specs through MCP",
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "design-tokens",
    "unity",
    "react",
    "react-native",
    "flutter",
    "swiftui",
    "tailwind",
    "figma-to-code",
    "figma-to-unity",
    "figma-to-react",
    "figma-to-flutter",
    "layout-audit",
    "accessibility",
    "ai-agents",
    "design-system",
    "ai",
    "claude",
    "cursor",
    "game-development",
    "mobile-development"
  ],
  "homepage": "https://github.com/zaferdace/figma-spec-mcp",
  "bugs": {
    "url": "https://github.com/zaferdace/figma-spec-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaferdace/figma-spec-mcp.git"
  },
  "license": "MIT",
  "author": "Zafer Dace",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "figma-spec-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "publint": "publint",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/ && publint",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/rest-api-spec": "^0.36.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
